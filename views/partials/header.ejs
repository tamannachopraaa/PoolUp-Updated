<header class="main-header">
    <nav class="nav-container">
        <a href="/" class="nav-logo">PoolUp</a>
        <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="main-navigation">☰ Menu</button>
        <ul class="nav-links" id="main-navigation">
            <% if (typeof user !== 'undefined' && user) { %>
                <li><a href="/">Dashboard</a></li>
                <% if (user.role === 'admin') { %>
                    <li><a href="/admin/manage-offers">Manage Offers</a></li>
                    <li><a href="/admin/manage-users">Manage Users</a></li>
                <% } else { %>
                    <li><a href="/carpools/new">Create Offer</a></li>
                    <li><a href="/my-trips">My Trips</a></li>
                <% } %>
                <li class="notif-menu">
                    <a href="#" class="notif-trigger" title="Notifications" aria-expanded="false" aria-controls="notif-dropdown"><span class="notif-icon">🔔</span><span>Notifications</span><% if (unreadNotifications > 0) { %><span class="notif-count"><%= unreadNotifications %></span><% } %></a>
                    <div class="notif-dropdown" id="notif-dropdown" role="menu" aria-label="Notifications">
                        <div class="notif-head">
                            <strong>Notifications</strong>
                            <% if (unreadNotifications > 0) { %>
                                <form action="/notifications/read-all" method="POST" data-toast-message="All notifications marked as read">
                                    <button type="submit" class="notif-readall" data-loading-text="Saving...">Mark all read</button>
                                </form>
                            <% } %>
                        </div>
                        <% if (notifications && notifications.length > 0) { %>
                            <ul class="notif-list">
                                <% notifications.forEach((item) => { %>
                                    <li class="notif-item <%= item.isRead ? 'read' : 'unread' %>">
                                        <a href="<%= item.link || '/' %>" class="notif-message"><%= item.message %></a>
                                        <div class="notif-meta">
                                            <span><%= item.createdAt ? new Date(item.createdAt).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short' }) : '' %></span>
                                            <% if (!item.isRead) { %>
                                                <form action="/notifications/<%= item._id %>/read" method="POST" data-toast-message="Notification marked as read">
                                                    <button type="submit" class="notif-mark" data-loading-text="Saving...">Mark as read</button>
                                                </form>
                                            <% } else { %>
                                                <span class="notif-read-label">Read</span>
                                            <% } %>
                                        </div>
                                    </li>
                                <% }) %>
                            </ul>
                        <% } else { %>
                            <p class="notif-empty">No notifications yet.</p>
                        <% } %>
                    </div>
                </li>
                <li><a href="/logout">Logout</a></li>
            <% } else { %>
                <li><a href="/auth/login-register">Login / Register</a></li>
            <% } %>
        </ul>
    </nav>
</header>