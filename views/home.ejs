<% if (typeof user !== 'undefined' && user) { %>
	<div class="page-container">
		<div class="page-header">
			<h2>Welcome, <%= user.name %>!</h2>

			<h3>
				<% if (user.role === 'admin') { %>
					Available Offers (Admin View)
				<% } else { %>
					Available Carpool Offers
				<% } %>
			</h3>
		</div>

		<%
			const now = new Date();
			const isAdmin = user.role === 'admin';

			let upcomingRides = 0;
			let completedRides = 0;
			let cancelledRides = 0;

			function rideBelongsToUser(carpool) {
				if (isAdmin) return true;

				const ownerId = carpool.userId && (carpool.userId._id ? carpool.userId._id : carpool.userId);

				if (ownerId && String(ownerId) === String(user.id)) return true;
				if (!carpool.bookedBy) return false;

				return carpool.bookedBy.some((b) => {
					const bid = b.user ? (b.user._id ? b.user._id : b.user) : null;
					return bid && String(bid) === String(user.id);
				});
			}

			function rideDate(carpool) {
				if (carpool && carpool.time) {
					const t = new Date(carpool.time);
					if (!isNaN(t.getTime())) return t;
				}

				if (carpool && carpool.createdAt) {
					const base = new Date(carpool.createdAt);

					if (!isNaN(base.getTime())) {
						if (typeof carpool.time === 'string' && /^\d{1,2}:\d{2}/.test(carpool.time)) {
							const parts = carpool.time.split(':');
							const hh = parseInt(parts[0], 10) || 0;
							const mm = parseInt(parts[1], 10) || 0;

							base.setHours(hh, mm, 0, 0);
						}

						return base;
					}
				}

				return now;
			}

			if (carpools && carpools.length > 0) {
				carpools.forEach((carpool) => {
					if (!rideBelongsToUser(carpool)) return;

					const when = rideDate(carpool);
					const ownerId = carpool.userId && (carpool.userId._id ? carpool.userId._id : carpool.userId);
					const isOwner = ownerId && String(ownerId) === String(user.id);
					const userHasBooked =
						carpool.bookedBy &&
						carpool.bookedBy.some((b) => {
							const bid = b.user ? (b.user._id ? b.user._id : b.user) : null;
							return bid && String(bid) === String(user.id);
						});

					if (when > now) {
						upcomingRides++;
					} else if (isAdmin || isOwner || userHasBooked) {
						completedRides++;
					} else {
						cancelledRides++;
					}
				});
			}
		%>

		<div class="summary-grid">
			<div class="summary-card">
				<div class="summary-icon">🚐</div>
				<div>
					<p class="summary-label">Upcoming rides</p>
					<p class="summary-value"><%= upcomingRides %></p>
				</div>
			</div>

			<div class="summary-card">
				<div class="summary-icon">✅</div>
				<div>
					<p class="summary-label">Completed rides</p>
					<p class="summary-value"><%= completedRides %></p>
				</div>
			</div>

			<% if (!isAdmin) { %>
				<div class="summary-card">
					<div class="summary-icon">↩️</div>
					<div>
						<p class="summary-label">Expired rides</p>
						<p class="summary-value"><%= cancelledRides %></p>
					</div>
				</div>
			<% } %>
		</div>

		<% if (user.role !== 'admin') { %>
			<div style="text-align:center;margin-bottom:2rem;">
				<a href="/carpools/new" class="btn btn-primary">Create a New Offer</a>
			</div>
		<% } %>

		<div class="carpool-grid">
			<% if (carpools && carpools.length > 0) { %>
				<% carpools.forEach((carpool) => { %>
					<%
						const rideTime = rideDate(carpool);
						const isExpiredRide = rideTime <= now;
						const ownerId = carpool.userId && (carpool.userId._id ? carpool.userId._id : carpool.userId);
						const isOwner = ownerId && String(ownerId) === String(user.id);
						let userHasBooked = false;
						let userBooking = null;
						let userInWaitlist = false;
						const bookedUsers = [];
						const waitlistedUsers = [];

						if (carpool.bookedBy) {
							carpool.bookedBy.forEach((b) => {
								const bid = b.user ? (b.user._id ? b.user._id : b.user) : null;
								const bookedName = b.user && b.user.name ? b.user.name : 'User';
								bookedUsers.push(`${bookedName} (${b.seats || 1})`);

								if (bid && String(bid) === String(user.id)) {
									userHasBooked = true;
									userBooking = b;
								}
							});
						}

						if (carpool.waitlist) {
							carpool.waitlist.forEach((w) => {
								const wid = w.user ? (w.user._id ? w.user._id : w.user) : null;
								const waitlistName = w.user && w.user.name ? w.user.name : 'User';
								waitlistedUsers.push(`${waitlistName} (${w.seats || 1})`);
								if (wid && String(wid) === String(user.id)) {
									userInWaitlist = true;
								}
							});
						}

						let rideStatus = 'upcoming';
						let rideStatusLabel = '🟦 Upcoming';

						if (isExpiredRide && (isAdmin || isOwner || userHasBooked)) {
							rideStatus = 'completed';
							rideStatusLabel = '✅ Completed';
						} else if (isExpiredRide) {
							rideStatus = 'expired';
							rideStatusLabel = '⛔ Expired';
						}
					%>

					<div class="carpool-card">
						<div>
							<div class="ride-status <%= rideStatus %>">
								<%= rideStatusLabel %>
							</div>
							<h4><%= carpool.carName %></h4>
							<p><strong>From:</strong> <%= carpool.location %></p>
							<p>
								<strong>Time:</strong>
								<%= rideTime.toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short' }) %>
							</p>
							<p><strong>Price:</strong> ₹<%= carpool.price %></p>

							<%
								const seatsFree = (carpool.totalSeats || 0) - (carpool.bookedSeats || 0);
							%>

							<p><strong>Seats Available:</strong> <%= seatsFree %>/<%= carpool.totalSeats %></p>
							<p><strong>Driver:</strong> <%= carpool.userId && carpool.userId.name ? carpool.userId.name : 'Driver' %></p>
							<p><strong>Preference:</strong> <%= carpool.gender %></p>

							<% if (isAdmin || isOwner) { %>
								<p><strong>Booked By:</strong> <%= bookedUsers.length > 0 ? bookedUsers.join(', ') : 'No bookings yet' %></p>
								<p><strong>Waitlist:</strong> <%= waitlistedUsers.length > 0 ? waitlistedUsers.join(', ') : 'No one in waitlist' %></p>
							<% } %>
						</div>

						<div class="card-footer">
							<% if (user.role === 'admin') { %>
								<form action="/admin/offers/<%= carpool._id %>?_method=DELETE" method="POST">
									<button class="btn btn-danger">Delete (Admin)</button>
								</form>
							<% } else { %>
								<%
									const availableSeats = (carpool.totalSeats || 0) - (carpool.bookedSeats || 0);
								%>

								<% if (isOwner) { %>
									<span class="btn" style="border:1px solid var(--glow-blue);color:var(--glow-blue);cursor:default;">
										Your Offer
									</span>
								<% } else if (isExpiredRide) { %>
									<% if (userHasBooked) { %>
										<button class="btn btn-success" disabled>✓ Completed Ride</button>
									<% } else { %>
										<button class="btn btn-expired" disabled>⛔ Expired</button>
									<% } %>
								<% } else if (userHasBooked) { %>
									<p class="booked-info">
										<strong>You booked:</strong>
										<%= userBooking.seats || 1 %> seat
									</p>

									<form action="/carpools/<%= carpool._id %>/cancel" method="POST">
										<button class="btn btn-danger">Cancel Booking</button>
									</form>
								<% } else if (availableSeats > 0) { %>
									<form action="/carpools/<%= carpool._id %>/book" method="POST" style="display:flex;gap:8px;">
										<select name="seats">
											<% for (let i = 1; i <= availableSeats; i++) { %>
												<option value="<%= i %>"><%= i %> seat<%= i > 1 ? 's' : '' %></option>
											<% } %>
										</select>

										<button class="btn btn-primary">Book</button>
									</form>
								<% } else if (userInWaitlist) { %>
									<button class="btn" disabled>⏳ Waitlisted</button>
								<% } else { %>
									<form action="/carpools/<%= carpool._id %>/waitlist" method="POST" style="display:flex;gap:8px;">
										<input type="hidden" name="seats" value="1" />
										<button class="btn btn-secondary">Join Waitlist</button>
									</form>
								<% } %>
							<% } %>

							<a href="/chat/<%= carpool._id %>" class="btn btn-secondary">Chat</a>
						</div>
					</div>
				<% }) %>
			<% } else { %>
				<p style="text-align:center;grid-column:1/-1;">No carpool offers available at the moment.</p>
			<% } %>
		</div>
	</div>
<% } else { %>
	<div class="page-container">
		<div class="hero-container">
			<h1 style="font-size:4.5rem;line-height:1.2;">
				University Carpooling,<br />Reimagined.
			</h1>

			<p style="font-size:1.2rem;max-width:550px;margin:1rem auto 2.5rem;">
				The smart, affordable, and eco-friendly way for students to commute. Find your ride or offer a seat in just a few clicks.
			</p>

			<a href="/auth/login-register" class="btn btn-primary">Get Started</a>
		</div>

		<div class="benefits-section">
			<div class="page-header" style="margin-bottom:3rem;">
				<h2 style="font-size:2.5rem;">Why PoolUp?</h2>
			</div>

			<div class="carpool-grid">
				<div class="carpool-card">
					<h4>💰 Save Money</h4>
					<p>Split fuel and toll costs with fellow students. It's the most affordable way to get to and from campus every day.</p>
				</div>

				<div class="carpool-card">
					<h4>🤝 Connect &amp; Network</h4>
					<p>Meet new people from different courses and build your university network. Your next ride could be with your next study partner!</p>
				</div>

				<div class="carpool-card">
					<h4>🌍 Eco-Friendly Travel</h4>
					<p>Reduce traffic congestion and lower your carbon footprint. Every shared ride helps create a greener campus environment.</p>
				</div>
			</div>
		</div>

		<div class="cta-section">
			<h2>Join Hundreds of Students</h2>
			<p>Ready to make your commute easier, cheaper, and more enjoyable? Sign up in seconds and find your perfect ride today.</p>
			<a href="/auth/login-register" class="btn btn-primary">Sign Up Now</a>
		</div>
	</div>
<% } %>